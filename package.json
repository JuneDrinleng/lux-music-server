{
  "name": "lux-music-server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "rimraf server && tsc --project tsconfig.json && tsc-alias -p tsconfig.json && npm run build:admin && node -e \"const fs=require('fs');fs.rmSync('server/server/web',{recursive:true,force:true});fs.cpSync('admin-ui/dist','server/server/web',{recursive:true});\"",
    "build:admin": "tsc -p admin-ui/tsconfig.json --noEmit && vite build --config admin-ui/vite.config.mjs",
    "dev:admin": "vite --config admin-ui/vite.config.mjs",
    "start": "node ./index.js",
    "dev": "nodemon",
    "prd": "pm2 start ecosystem.config.js --env production",
    "publish": "node publish"
  },
  "engines": {
    "node": ">= 24",
    "npm": ">= 10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuneDrinleng/lux-music-server.git"
  },
  "author": {
    "name": "lyswhut",
    "email": "lyswhut@qq.com"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/JuneDrinleng/lux-music-server/issues"
  },
  "homepage": "https://github.com/JuneDrinleng/lux-music-server#readme",
  "dependencies": {
    "bufferutil": "^4.0.8",
    "fastify": "^4.29.1",
    "log4js": "^6.9.1",
    "lru-cache": "^10.0.1",
    "message2call": "^0.1.3",
    "utf-8-validate": "^6.0.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node16": "^16.1.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "8.5.4",
    "@vitejs/plugin-react": "^6.0.3",
    "chalk": "^4.1.2",
    "changelog-parser": "^3.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "lucide-react": "^1.22.0",
    "nodemon": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^5.0.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.2.2",
    "vite": "^8.1.2"
  },
  "nodemonConfig": {
    "ext": "js,ts",
    "ignore": [],
    "exec": "node -r ts-node/register -r tsconfig-paths/register ./src/index.ts"
  }
}
